# Alpaca (paper trading - https://alpaca.markets)
ALPACA_API_KEY=YOUR_KEY_HERE
ALPACA_SECRET_KEY=YOUR_SECRET_HERE
# Use "live" only with a funded live account; paper is safer to start
ALPACA_MODE=paper

# Polygon.io (optional; leave blank to use yfinance)
POLYGON_API_KEY=

# FRED macro data - https://fred.stlouisfed.org
FRED_API_KEY=YOUR_FRED_KEY_HERE

# X / Twitter sentiment via twikit (optional, no API key)
# Use a burner account, not your main account
X_USERNAME=
X_PASSWORD=
X_EMAIL=
# Cookies saved to x_cookies.json after first login

# App settings
# Ticker: set DEFAULT_TICKER in config.py (or POST /api/config).
CANDLE_INTERVAL=15m
MC_MODEL=garch
MC_SIMULATIONS=2000
MC_FORWARD_CANDLES=5
PORT=8000
HOST=127.0.0.1

# Security
# Random string to gate mutation endpoints via X-Api-Key header.
# Leave blank to disable (local use only).
API_KEY=

# AI Analyst (Claude) - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model for /api/ai/analyze
CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_MAX_TOKENS=4096
