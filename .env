# ── Alpaca (free paper trading account at alpaca.markets) ──────────────────
# Sign up free at https://alpaca.markets → get API keys from dashboard
ALPACA_API_KEY= YOUR_API_HERE
ALPACA_SECRET_KEY= YOUR_SECRET_HERE
# Set to "live" only when using a funded live account — paper is safer to start
ALPACA_MODE=paper

# ── Polygon.io (optional, paid, real-time) ─────────────────────────────────
# Leave blank to use yfinance (free, ~15 min delayed) instead
POLYGON_API_KEY=

# ── X / Twitter (social sentiment via twikit — free, no API key needed) ──
# 1. pip install twikit
# 2. Use a BURNER account — not your main account
# 3. Fill in your X username (handle without @) and password below
X_USERNAME=YOUR_USER_HERE
X_PASSWORD=YOUR_PASSWORD_HERE
X_EMAIL=YOUR_EMAIL_HERE
# Cookies are saved to x_cookies.json after first login (no re-login on restart)

# ── App settings ──────────────────────────────────────────────────────────
TICKER=NBIS
CANDLE_INTERVAL=15m
MC_SIMULATIONS=10000
MC_FORWARD_CANDLES=10
PORT=8000 
