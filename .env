# ── Alpaca (free paper trading account at alpaca.markets) ──────────────────
# Sign up free at https://alpaca.markets → get API keys from dashboard
ALPACA_API_KEY= YOUR_API_HERE
ALPACA_SECRET_KEY= YOUR_KEY_HERE
# Set to "live" only when using a funded live account — paper is safer to start
ALPACA_MODE=paper

# ── Polygon.io (optional, paid, real-time) ─────────────────────────────────
# Leave blank to use yfinance (free, ~15 min delayed) instead
POLYGON_API_KEY=

# ── App settings ──────────────────────────────────────────────────────────
TICKER=PLTR
CANDLE_INTERVAL=15m
MC_SIMULATIONS=500
MC_FORWARD_CANDLES=10
PORT=8000
